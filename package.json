{
  "name": "war-world-ascendants",
  "version": "0.1.0",
  "description": "WAR WORLD: ASCENDANTS \u2014 isometric superhuman action. 1,050 real cities, 168 real nations.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "desktop": "npm run build && electron .",
    "desktop:win": "npm run build && electron-builder --win --publish never",
    "desktop:linux": "npm run build && electron-builder --linux --publish never",
    "desktop:all": "npm run build && electron-builder --win --linux --publish never"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "vite": "^5.4.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.8",
    "three": "^0.169.0"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.machinekinglabs.warworldascendants",
    "productName": "War World Ascendants",
    "directories": {
      "output": "release",
      "buildResources": "electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "WarWorldAscendants-${version}-win-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "War World: Ascendants"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Game",
      "artifactName": "WarWorldAscendants-${version}-linux-x64.${ext}",
      "executableName": "war-world-ascendants"
    },
    "compression": "maximum"
  }
}